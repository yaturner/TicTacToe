<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="@string/app_name"
        android:theme="@style/PluginTheme">

        <meta-data
            android:name="plugin.id"
            android:value="com.codeonthego.tictactoe" />

        <meta-data
            android:name="plugin.name"
            android:value="Tic-Tac-Toe" />

        <meta-data
            android:name="plugin.version"
            android:value="${pluginVersion}" />

        <meta-data
            android:name="plugin.description"
            android:value="Play tic-tac-toe with another device on your local WiFi — no server, no signup." />

        <meta-data
            android:name="plugin.author"
            android:value="App Dev For All" />

        <meta-data
            android:name="plugin.min_ide_version"
            android:value="1.0.0" />

        <meta-data
            android:name="plugin.permissions"
            android:value="network.access" />

        <meta-data
            android:name="plugin.main_class"
            android:value="com.codeonthego.tictactoe.TicTacToePlugin" />

        <meta-data
            android:name="plugin.sidebar_items"
            android:value="1" />

    </application>

</manifest>
